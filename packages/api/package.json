{
  "name": "@shelfshare/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc && node -e \"require('esbuild').buildSync({entryPoints:['dist/index.js'],bundle:true,platform:'node',target:'node20',outfile:'dist/index.js',allowOverwrite:true,external:['pg-native']})\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1018.0",
    "@aws-sdk/client-secrets-manager": "^3.1018.0",
    "@aws-sdk/client-sqs": "^3.1018.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@shelfshare/shared": "*",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/ioredis": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "esbuild": "^0.27.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "*"
  }
}
